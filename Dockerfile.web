FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/package.json
COPY libs/shared/types/package.json ./libs/shared/types/package.json
COPY libs/web/data-access/package.json ./libs/web/data-access/package.json
COPY libs/web/ui/package.json ./libs/web/ui/package.json
RUN pnpm install --frozen-lockfile --prod=false

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json ./package.json
COPY --from=deps /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY nx.json ./
COPY tsconfig.base.json ./
COPY apps/web ./apps/web
COPY libs ./libs
RUN pnpm nx build web --prod

FROM nginx:alpine AS runner
# Copy built app
COPY --from=builder /app/dist/apps/web /usr/share/nginx/html

# Create a simple startup script that configures nginx
RUN echo '#!/bin/sh' > /docker-entrypoint.sh && \
    echo 'PORT=${PORT:-80}' >> /docker-entrypoint.sh && \
    echo 'cat > /etc/nginx/conf.d/default.conf << EOF' >> /docker-entrypoint.sh && \
    echo 'server {' >> /docker-entrypoint.sh && \
    echo '    listen $PORT;' >> /docker-entrypoint.sh && \
    echo '    server_name _;' >> /docker-entrypoint.sh && \
    echo '    root /usr/share/nginx/html;' >> /docker-entrypoint.sh && \
    echo '    index index.html;' >> /docker-entrypoint.sh && \
    echo '    location / {' >> /docker-entrypoint.sh && \
    echo '        try_files \$uri \$uri/ /index.html;' >> /docker-entrypoint.sh && \
    echo '    }' >> /docker-entrypoint.sh && \
    echo '    location /assets {' >> /docker-entrypoint.sh && \
    echo '        expires 1y;' >> /docker-entrypoint.sh && \
    echo '        add_header Cache-Control "public, immutable";' >> /docker-entrypoint.sh && \
    echo '    }' >> /docker-entrypoint.sh && \
    echo '    gzip on;' >> /docker-entrypoint.sh && \
    echo '    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;' >> /docker-entrypoint.sh && \
    echo '}' >> /docker-entrypoint.sh && \
    echo 'EOF' >> /docker-entrypoint.sh && \
    echo 'exec nginx -g "daemon off;"' >> /docker-entrypoint.sh && \
    chmod +x /docker-entrypoint.sh

EXPOSE 80
CMD ["/docker-entrypoint.sh"]
