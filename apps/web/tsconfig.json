{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@careerportal/shared/types": ["../../libs/shared/types/src/index.ts"],
      "@careerportal/shared/types/cv-templates": [
        "../../libs/shared/types/src/cv-templates.ts"
      ],
      "@careerportal/web/data-access": [
        "../../libs/web/data-access/src/index.ts"
      ],
      "@careerportal/web/ui": ["../../libs/web/ui/src/index.tsx"]
    }
  },
  "include": ["src", "../../libs"]
}
